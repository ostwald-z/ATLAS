## Banco
DB_PORT=3306
DB_NOME=backend_mind
DB_USER=root
DB_SENHA=ogwdamigodoben10

# tem que ser "mysql" pois isso vai rodar em DOCKER
DB_HOST=mysql

#JWT acessToken (15 minutos)
JWT_SECRET=

#15m
JWT_EXPIRES=15m

#JWT Refresh Token (15 dias)
JWT_REFRESH_SECRET=

#15d
JWT_REFRESH_EXPIRES=15d


#JWT LOGIN-INIT - necessário para fazer requisição de 2FA, pós login user e senha
JWT_SECRET_LOGIN_INIT=

#10m
JWT_SECRET_LOGIN_INIT_EXPIRES=10m

#server
PORT=8080  # pré definido por causa do docker

#mudar para "prod" para já configurar cookies automatico
#development para testes  locais.
NODE_ENV=


#padrão localhost: http://127.0.0.1:3000
FRONTEND_URL=

#produção é https://atlas.ostwald.top


#encriptar com bcrypt denovo após decidido qual chaves irá ser no futuro
# deve estar em HASH, feito pelo bcrypt
MAGIC_WORD_CRIAR=
MAGIC_WORD_ROLE=
CHAVE_IMPERSONATE=
CHAVE_NOPENDING=



#sobre CAMINHO DO ATLAS CLOUD
#exemplo: "C://atlas-drive-cloud"

# app / cloud pois é onde fica dentro do container DOCKER
ATLAS_CLOUD_PATH=/app/cloud




# Mailer Send API CONFIGURAÇÃO
# API ligada ao dominio registrado resposável por ENVIAR EMAIL de aviso de login na cont dos usuários.
# MailerSend
EMAILSENDER_API_KEY=



# caminho pra onde fica os LOGS do sistema dentro do container ( DOCKER )
CAMINHO_ATLAS_LOGS=/app/logs



# caminho onde os arquivos VAULTS ficam dentro do container (DOCKER)
CAMINHO_VAULTS=/app/vaults



#TOKEN DO BOT TELEGRAM KIMI, para envio de notificações.
KIMI_BOT_TOKEN=
CHAT_ID_TELEGRAM_ADMIN=
